function PipelineTab({ leads }) {
  const [filterStatus, setFilterStatus] = useState("todos");
  const [filterCat, setFilterCat] = useState("todas");
  const [search, setSearch] = useState("");

  const categorias = [...new Set(leads.map((l) => l.categoria).filter(Boolean))];

  const filtered = leads.filter((l) => {
    const matchStatus = filterStatus === "todos" || l.status === filterStatus;
    const matchCat = filterCat === "todas" || l.categoria === filterCat;
    const matchSearch = !search || (l.nome || "").toLowerCase().includes(search.toLowerCase());
    return matchStatus && matchCat && matchSearch;
  });

  const statusColors = {
    novo: { bg: "#64748B20", color: "#94A3B8" },
    contactado: { bg: "#38BDF820", color: "#38BDF8" },
    interessado: { bg: "#34D39920", color: "#34D399" },
    nao_quer: { bg: "#EF444420", color: "#EF4444" },
    convertido: { bg: "#A78BFA20", color: "#A78BFA" },
  };

  return (
    <div>
      <h1 style={{ fontSize: 22, fontWeight: 700, marginBottom: 24, color: "#F1F5F9" }}>Pipeline de Leads ({leads.length})</h1>

      <div style={{ display: "flex", gap: 10, marginBottom: 20, flexWrap: "wrap" }}>
        <div style={{ position: "relative" }}>
          <Search size={14} style={{ position: "absolute", left: 10, top: "50%", transform: "translateY(-50%)", color: "#64748B" }} />
          <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Buscar lead..." style={{
            padding: "8px 12px 8px 32px", background: "#1E293B", border: "1px solid #334155", borderRadius: 8, color: "#E2E8F0", fontSize: 13, width: 200, outline: "none",
          }} />
        </div>
        {["todos", "novo", "contactado", "interessado", "nao_quer"].map((s) => (
          <button key={s} onClick={() => setFilterStatus(s)} style={{
            padding: "8px 14px", background: filterStatus === s ? (statusColors[s]?.bg || "#38BDF820") : "#1E293B",
            border: `1px solid ${filterStatus === s ? (statusColors[s]?.color || "#38BDF8") : "#334155"}`,
            borderRadius: 8, color: filterStatus === s ? (statusColors[s]?.color || "#38BDF8") : "#94A3B8", fontSize: 12, cursor: "pointer",
          }}>
            {s === "todos" ? "Todos" : s === "nao_quer" ? "Não quer" : s.charAt(0).toUpperCase() + s.slice(1)}
          </button>
        ))}
        {categorias.length > 0 && (
          <select value={filterCat} onChange={(e) => setFilterCat(e.target.value)} style={{
            padding: "8px 12px", background: "#1E293B", border: "1px solid #334155", borderRadius: 8, color: "#94A3B8", fontSize: 12, outline: "none",
          }}>
            <option value="todas">Todas categorias</option>
            {categorias.map((c) => <option key={c} value={c}>{c}</option>)}
          </select>
        )}
      </div>

      <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, overflow: "hidden" }}>
        <table style={{ width: "100%", borderCollapse: "collapse" }}>
          <thead>
            <tr style={{ background: "#0F172A" }}>
              {["Nome", "Categoria", "Cidade", "Telefone", "Status", "Respondeu", "Data"].map((h) => (
                <th key={h} style={{ padding: "12px 16px", textAlign: "left", fontSize: 11, fontWeight: 600, color: "#64748B", textTransform: "uppercase" }}>
                  {h}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filtered.slice(0, 100).map((l, i) => {
              const sc = statusColors[l.status] || statusColors.novo;
              return (
                <tr key={l.id || i} style={{ borderBottom: "1px solid #1E293B" }}>
                  <td style={{ padding: "10px 16px", fontSize: 13, color: "#E2E8F0" }}>{l.nome || "—"}</td>
                  <td style={{ padding: "10px 16px", fontSize: 12, color: "#94A3B8" }}>{l.categoria || "—"}</td>
                  <td style={{ padding: "10px 16px", fontSize: 12, color: "#94A3B8" }}>{l.cidade || "—"}</td>
                  <td style={{ padding: "10px 16px", fontSize: 12, color: "#64748B" }}>{l.telefone || "—"}</td>
                  <td style={{ padding: "10px 16px" }}>
                    <span style={{ fontSize: 11, padding: "3px 8px", borderRadius: 6, background: sc.bg, color: sc.color }}>
                      {l.status || "novo"}
                    </span>
                  </td>
                  <td style={{ padding: "10px 16px" }}>
                    {l.respondeu_whatsapp ? <CheckCircle size={14} color="#34D399" /> : <Clock size={14} color="#475569" />}
                  </td>
                  <td style={{ padding: "10px 16px", fontSize: 11, color: "#64748B" }}>
                    {l.created_at ? new Date(l.created_at).toLocaleDateString("pt-BR") : "—"}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {filtered.length === 0 && (
          <div style={{ padding: 40, textAlign: "center", color: "#475569", fontSize: 13 }}>Nenhum lead encontrado</div>
        )}
        {filtered.length > 100 && (
          <div style={{ padding: 12, textAlign: "center", color: "#64748B", fontSize: 12 }}>Mostrando 100 de {filtered.length} leads</div>
        )}
      </div>
    </div>
  );
}

