      }}>
        <div style={{ fontSize: 20, fontWeight: 700, color: "#38BDF8", marginBottom: 4 }}>VitrineIA</div>
        <div style={{ fontSize: 13, color: "#64748B", marginBottom: 28 }}>Configure suas credenciais para conectar ao painel.</div>

        {[
          { key: "supabaseUrl", label: "Supabase URL", placeholder: "https://xxxxx.supabase.co" },
          { key: "supabaseKey", label: "Supabase Key (anon)", placeholder: "eyJ..." },
          { key: "anthropicKey", label: "Anthropic API Key (para IA Analista)", placeholder: "sk-ant-..." },
        ].map((field) => (
          <div key={field.key} style={{ marginBottom: 16 }}>
            <label style={{ display: "block", fontSize: 12, fontWeight: 600, color: "#94A3B8", marginBottom: 6 }}>{field.label}</label>
            <input
              value={form[field.key]}
              onChange={(e) => setForm({ ...form, [field.key]: e.target.value })}
              placeholder={field.placeholder}
              type={field.key.includes("Key") ? "password" : "text"}
              style={{
                width: "100%", padding: "10px 14px", background: "#0F172A", border: "1px solid #334155",
                borderRadius: 8, color: "#E2E8F0", fontSize: 13, outline: "none",
              }}
