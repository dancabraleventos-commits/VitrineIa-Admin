function AnalistaTab({ clientes, paginas, config }) {
  const [selectedCliente, setSelectedCliente] = useState(null);
  const [analyzing, setAnalyzing] = useState(false);
  const [report, setReport] = useState(null);

  const analyzePageIA = async (cliente) => {
    if (!config.anthropicKey) {
      setReport({ erro: "Configure sua API Key da Anthropic nas Configurações." });
      return;
    }

    setAnalyzing(true);
    setReport(null);

    const pagina = paginas.find((p) => p.cliente_id === cliente.id);
    if (!pagina?.html_completo) {
      setReport({ erro: "Página não encontrada para este cliente." });
      setAnalyzing(false);
      return;
    }

    // Truncar HTML para não estourar contexto
    const htmlTruncado = pagina.html_completo.substring(0, 15000);

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 2000,
          messages: [{
            role: "user",
            content: `Você é um consultor de conversão e marketing digital. Analise esta landing page de um comércio local e dê um relatório prático.

NEGÓCIO: ${cliente.nome || "?"} — ${cliente.segmento || "?"} — ${cliente.cidade || "?"}
URL: ${pagina.url_publica || "?"}

HTML DA PÁGINA (truncado):
${htmlTruncado}

Retorne SOMENTE JSON válido com esta estrutura:
{
  "nota_geral": 8.5,
  "pontos_fortes": ["ponto 1", "ponto 2", "ponto 3"],
  "problemas": ["problema 1", "problema 2", "problema 3"],
  "objecoes_previstas": ["objeção que visitantes podem ter 1", "objeção 2"],
  "sugestoes_melhoria": ["sugestão específica 1", "sugestão 2", "sugestão 3"],
  "addons_recomendados": ["addon que faria diferença"],
  "taxa_conversao_estimada": "2-4%",
  "resumo": "2 frases resumindo a análise"
}
Sem markdown, sem explicações, só JSON.`
          }],
        }),
      });

      const data = await response.json();
      const text = data.content?.[0]?.text || "";
      const parsed = JSON.parse(text.replace(/```json|```/g, "").trim());
      setReport(parsed);
    } catch (e) {
      console.error("Erro na análise:", e);
      setReport({ erro: "Erro ao analisar. Verifique sua API Key e tente novamente." });
    }
    setAnalyzing(false);
  };

  return (
    <div>
      <h1 style={{ fontSize: 22, fontWeight: 700, marginBottom: 8, color: "#F1F5F9" }}>IA Analista</h1>
      <p style={{ fontSize: 13, color: "#64748B", marginBottom: 24 }}>Selecione um cliente para a IA analisar a página, taxa de conversão e sugerir melhorias.</p>

      <div style={{ display: "grid", gridTemplateColumns: "300px 1fr", gap: 20 }}>
        {/* Lista de clientes */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 16, maxHeight: 500, overflow: "auto" }}>
          <div style={{ fontSize: 12, fontWeight: 600, color: "#64748B", marginBottom: 12 }}>CLIENTES ATIVOS</div>
          {clientes.map((c) => (
            <button key={c.id} onClick={() => { setSelectedCliente(c); setReport(null); }} style={{
              display: "block", width: "100%", textAlign: "left", padding: "10px 12px", marginBottom: 4,
              background: selectedCliente?.id === c.id ? "#38BDF815" : "transparent",
              border: `1px solid ${selectedCliente?.id === c.id ? "#38BDF840" : "transparent"}`,
              borderRadius: 8, cursor: "pointer", color: "#E2E8F0",
            }}>
              <div style={{ fontSize: 13, fontWeight: 500 }}>{c.nome || "Sem nome"}</div>
              <div style={{ fontSize: 11, color: "#64748B" }}>{c.segmento || "—"}</div>
            </button>
          ))}
          {clientes.length === 0 && <div style={{ color: "#475569", fontSize: 12 }}>Nenhum cliente ativo</div>}
        </div>

        {/* Resultado da análise */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 24 }}>
          {!selectedCliente ? (
            <div style={{ textAlign: "center", padding: 60, color: "#475569" }}>
              <Brain size={40} style={{ margin: "0 auto 12px", opacity: 0.3 }} />
              <p style={{ fontSize: 13 }}>Selecione um cliente para analisar</p>
            </div>
          ) : (
            <div>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 20 }}>
                <div>
                  <h3 style={{ fontSize: 16, fontWeight: 600, color: "#E2E8F0" }}>{selectedCliente.nome}</h3>
                  <div style={{ fontSize: 12, color: "#64748B" }}>{selectedCliente.segmento} · {selectedCliente.cidade}</div>
                </div>
                <button onClick={() => analyzePageIA(selectedCliente)} disabled={analyzing} style={{
                  display: "flex", alignItems: "center", gap: 8, padding: "10px 20px",
                  background: analyzing ? "#334155" : "#38BDF8", color: analyzing ? "#94A3B8" : "#0B1120",
                  border: "none", borderRadius: 8, fontSize: 13, fontWeight: 600, cursor: analyzing ? "default" : "pointer",
                }}>
                  <Brain size={16} className={analyzing ? "spin" : ""} />
                  {analyzing ? "Analisando..." : "Analisar com IA"}
                </button>
              </div>

              {report?.erro && (
                <div style={{ padding: 16, background: "#EF444420", border: "1px solid #EF444440", borderRadius: 8, color: "#FCA5A5", fontSize: 13 }}>
                  {report.erro}
                </div>
              )}

              {report && !report.erro && (
                <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
                  {/* Nota e Resumo */}
                  <div style={{ display: "flex", gap: 16, alignItems: "center" }}>
                    <div style={{
                      width: 70, height: 70, borderRadius: "50%", display: "flex", alignItems: "center", justifyContent: "center",
                      background: report.nota_geral >= 7 ? "#34D39920" : report.nota_geral >= 5 ? "#FB923C20" : "#EF444420",
                      border: `2px solid ${report.nota_geral >= 7 ? "#34D399" : report.nota_geral >= 5 ? "#FB923C" : "#EF4444"}`,
                      fontSize: 22, fontWeight: 700, color: report.nota_geral >= 7 ? "#34D399" : report.nota_geral >= 5 ? "#FB923C" : "#EF4444",
                    }}>
                      {report.nota_geral}
                    </div>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontSize: 13, color: "#E2E8F0", marginBottom: 4 }}>{report.resumo}</div>
                      <div style={{ fontSize: 12, color: "#64748B" }}>Conversão estimada: <strong style={{ color: "#38BDF8" }}>{report.taxa_conversao_estimada}</strong></div>
                    </div>
                  </div>

                  {/* Sections */}
                  {[
                    { title: "Pontos Fortes", items: report.pontos_fortes, icon: CheckCircle, color: "#34D399" },
                    { title: "Problemas", items: report.problemas, icon: AlertTriangle, color: "#EF4444" },
                    { title: "Objeções dos Visitantes", items: report.objecoes_previstas, icon: Eye, color: "#FB923C" },
                    { title: "Sugestões de Melhoria", items: report.sugestoes_melhoria, icon: TrendingUp, color: "#38BDF8" },
                    { title: "Add-ons Recomendados", items: report.addons_recomendados, icon: Plus, color: "#A78BFA" },
                  ].map((section) => (
                    <div key={section.title}>
                      <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 8 }}>
                        <section.icon size={14} color={section.color} />
                        <span style={{ fontSize: 12, fontWeight: 600, color: section.color }}>{section.title}</span>
                      </div>
                      {section.items?.map((item, i) => (
                        <div key={i} style={{ padding: "6px 0 6px 20px", fontSize: 12, color: "#CBD5E1", borderLeft: `2px solid ${section.color}30` }}>
                          {item}
                        </div>
                      ))}
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

