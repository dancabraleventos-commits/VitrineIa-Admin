// FINANCEIRO TAB
// ═══════════════════════════════════════

function FinanceiroTab({ clientes, clientesAtivos, mrr, custoFixo, custoVariavel, lucro, margem }) {
  // Revenue by addon
  const addonRevenue = {};
  clientesAtivos.forEach((c) => {
    (c.addons || []).forEach((a) => {
      if (ADDONS[a]) addonRevenue[a] = (addonRevenue[a] || 0) + ADDONS[a].preco;
    });
  });

  const addonChartData = Object.entries(addonRevenue).map(([key, val]) => ({
    name: ADDONS[key]?.nome?.split(" ").slice(0, 2).join(" ") || key,
    valor: val,
  }));

  // Projection (12 months from current)
  const projectionData = [];
  let projClientes = clientesAtivos.length;
  for (let m = 1; m <= 12; m++) {
    projClientes = Math.floor(projClientes * 0.96 + (m <= 3 ? 8 : m <= 6 ? 12 : 6)); // growth - churn
    const projMRR = projClientes * 65; // ticket médio
    const projLucro = projMRR - custoFixo - projClientes * 6;
    projectionData.push({ mes: `M${m}`, clientes: projClientes, mrr: projMRR, lucro: Math.max(0, projLucro) });
  }

  const COLORS = ["#38BDF8", "#34D399", "#A78BFA", "#FB923C", "#F472B6", "#FBBF24"];

  const pieData = [
    { name: "Plano Base", value: clientesAtivos.length * PLANO_BASE },
    ...addonChartData.map((d) => ({ name: d.name, value: d.valor })),
  ];

  return (
    <div>
      <h1 style={{ fontSize: 22, fontWeight: 700, marginBottom: 24, color: "#F1F5F9" }}>Relatório Financeiro</h1>

      <div style={{ display: "flex", gap: 16, flexWrap: "wrap", marginBottom: 28 }}>
        <KpiCard icon={DollarSign} label="MRR Bruto" value={`R$${mrr.toFixed(0)}`} color="#34D399" />
        <KpiCard icon={TrendingUp} label="Lucro Líquido" value={`R$${lucro.toFixed(0)}`} sub={`Margem: ${margem}%`} color="#38BDF8" />
        <KpiCard icon={Activity} label="Custo Fixo" value={`R$${custoFixo}`} sub={`Variável: R$${custoVariavel}`} color="#FB923C" />
        <KpiCard icon={Users} label="Ticket Médio" value={`R$${clientesAtivos.length > 0 ? (mrr / clientesAtivos.length).toFixed(0) : 0}`} color="#A78BFA" />
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20, marginBottom: 20 }}>
        {/* Projeção 12 meses */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20 }}>
          <h3 style={{ fontSize: 14, fontWeight: 600, color: "#94A3B8", marginBottom: 16 }}>Projeção 12 Meses</h3>
          <ResponsiveContainer width="100%" height={220}>
            <AreaChart data={projectionData}>
              <CartesianGrid strokeDasharray="3 3" stroke="#1E293B" />
              <XAxis dataKey="mes" stroke="#475569" fontSize={11} />
              <YAxis stroke="#475569" fontSize={11} />
              <Tooltip contentStyle={{ background: "#1E293B", border: "1px solid #334155", borderRadius: 8, fontSize: 12 }} />
              <Area type="monotone" dataKey="mrr" stroke="#38BDF8" fill="#38BDF820" name="MRR" />
              <Area type="monotone" dataKey="lucro" stroke="#34D399" fill="#34D39920" name="Lucro" />
            </AreaChart>
          </ResponsiveContainer>
        </div>

        {/* Receita por add-on */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20 }}>
          <h3 style={{ fontSize: 14, fontWeight: 600, color: "#94A3B8", marginBottom: 16 }}>Receita por Fonte</h3>
          {pieData.length > 0 ? (
            <ResponsiveContainer width="100%" height={220}>
              <PieChart>
                <Pie data={pieData} cx="50%" cy="50%" outerRadius={80} dataKey="value" label={({ name, value }) => `${name}: R$${value}`} fontSize={10}>
                  {pieData.map((_, i) => <Cell key={i} fill={COLORS[i % COLORS.length]} />)}
                </Pie>
                <Tooltip contentStyle={{ background: "#1E293B", border: "1px solid #334155", borderRadius: 8, fontSize: 12 }} />
              </PieChart>
            </ResponsiveContainer>
          ) : (
            <div style={{ textAlign: "center", padding: 60, color: "#475569", fontSize: 13 }}>Sem dados ainda</div>
          )}
        </div>
      </div>

      {/* Breakdown */}
      <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20 }}>
        <h3 style={{ fontSize: 14, fontWeight: 600, color: "#94A3B8", marginBottom: 16 }}>Composição do MRR</h3>
        <div style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12 }}>
          {[
            { label: "Planos Base", valor: clientesAtivos.length * PLANO_BASE, desc: `${clientesAtivos.length} × R$${PLANO_BASE}` },
            { label: "Add-ons", valor: Object.values(addonRevenue).reduce((s, v) => s + v, 0), desc: `${Object.keys(addonRevenue).length} tipos ativos` },
            { label: "Domínios", valor: clientesAtivos.filter((c) => c.addon_dominio).length * 9.9, desc: `${clientesAtivos.filter((c) => c.addon_dominio).length} domínios` },
          ].map((item, i) => (
            <div key={i} style={{ background: "#0F172A", borderRadius: 8, padding: 16 }}>
              <div style={{ fontSize: 12, color: "#64748B", marginBottom: 4 }}>{item.label}</div>
              <div style={{ fontSize: 20, fontWeight: 700, color: "#E2E8F0" }}>R${item.valor.toFixed(0)}</div>
              <div style={{ fontSize: 11, color: "#475569" }}>{item.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

