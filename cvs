
import { useState, useEffect, useCallback } from "react";
import { BarChart, Bar, LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, PieChart, Pie, Cell, AreaChart, Area } from "recharts";
import { Users, DollarSign, TrendingUp, Activity, Settings, Search, Eye, Pause, Play, Plus, ChevronRight, AlertTriangle, CheckCircle, Clock, Filter, RefreshCw, LayoutDashboard, UserCheck, Brain, PieChart as PieIcon, Zap, X, ExternalLink, Globe, Calendar, Star, Instagram, MessageCircle, ChevronDown } from "lucide-react";

// ═══════════════════════════════════════
// SUPABASE CLIENT (REST API)
// ═══════════════════════════════════════

const supabaseRequest = async (url, key, path, options = {}) => {
  const { method = "GET", body, params } = options;
  let fullUrl = `${url}/rest/v1/${path}`;
  if (params) fullUrl += `?${new URLSearchParams(params)}`;
  const res = await fetch(fullUrl, {
    method,
    headers: {
      apikey: key,
      Authorization: `Bearer ${key}`,
      "Content-Type": "application/json",
      Prefer: method === "PATCH" ? "return=representation" : "return=representation",
    },
    body: body ? JSON.stringify(body) : undefined,
  });
  if (!res.ok) throw new Error(`Supabase error: ${res.status}`);
  return res.json();
};

// ═══════════════════════════════════════
// ADDON CONFIG
// ═══════════════════════════════════════

const ADDONS = {
  dominio: { nome: "Domínio Próprio", icone: Globe, preco: 9.9 },
  agendamento: { nome: "Agendamento Online", icone: Calendar, preco: 29 },
  avaliacoes: { nome: "Avaliações Google", icone: Star, preco: 19 },
  instagram_posts: { nome: "Instagram Posts", icone: Instagram, preco: 39 },
  instagram_dm: { nome: "Instagram DM", icone: MessageCircle, preco: 19 },
  instagram_completo: { nome: "Instagram Completo", icone: Instagram, preco: 49 },
};

const PLANO_BASE = 47;

// ═══════════════════════════════════════
// MAIN APP
// ═══════════════════════════════════════

export default function Dashboard() {
  const [config, setConfig] = useState({ supabaseUrl: "", supabaseKey: "", anthropicKey: "" });
  const [configLoaded, setConfigLoaded] = useState(false);
  const [connected, setConnected] = useState(false);
  const [activeTab, setActiveTab] = useState("dashboard");
  const [clientes, setClientes] = useState([]);
  const [leads, setLeads] = useState([]);
  const [paginas, setPaginas] = useState([]);
  const [loading, setLoading] = useState(false);
  const [lastRefresh, setLastRefresh] = useState(null);

  // Load config from localStorage
  useEffect(() => {
    try {
      const saved = localStorage.getItem("vitrineia-config");
      if (saved) {
        const parsed = JSON.parse(saved);
        setConfig(parsed);
        if (parsed.supabaseUrl && parsed.supabaseKey) setConnected(true);
      }
    } catch (e) { /* no config yet */ }
    setConfigLoaded(true);
  }, []);

  // Save config
  const saveConfig = async (newConfig) => {
    setConfig(newConfig);
    localStorage.setItem("vitrineia-config", JSON.stringify(newConfig));
    if (newConfig.supabaseUrl && newConfig.supabaseKey) {
      setConnected(true);
      fetchData(newConfig);
    }
  };

  // Fetch all data
  const fetchData = useCallback(async (cfg) => {
    const c = cfg || config;
    if (!c.supabaseUrl || !c.supabaseKey) return;
    setLoading(true);
    try {
      const [clientesData, leadsData, paginasData] = await Promise.all([
        supabaseRequest(c.supabaseUrl, c.supabaseKey, "clientes", { params: { select: "*", order: "created_at.desc" } }),
        supabaseRequest(c.supabaseUrl, c.supabaseKey, "leads", { params: { select: "*", order: "created_at.desc", limit: "500" } }).catch(() => []),
        supabaseRequest(c.supabaseUrl, c.supabaseKey, "paginas", { params: { select: "*", order: "created_at.desc" } }).catch(() => []),
      ]);
      setClientes(clientesData || []);
      setLeads(leadsData || []);
      setPaginas(paginasData || []);
      setLastRefresh(new Date());
    } catch (e) {
      console.error("Fetch error:", e);
    }
    setLoading(false);
  }, [config]);

  useEffect(() => {
    if (connected) fetchData();
  }, [connected, fetchData]);

  // Toggle client active/paused
  const toggleCliente = async (id, ativo) => {
    await supabaseRequest(config.supabaseUrl, config.supabaseKey, `clientes?id=eq.${id}`, {
      method: "PATCH",
      body: { ativo: !ativo },
    });
    fetchData();
  };

  // Update client addons
  const updateAddons = async (id, addons) => {
    await supabaseRequest(config.supabaseUrl, config.supabaseKey, `clientes?id=eq.${id}`, {
      method: "PATCH",
      body: { addons },
    });
    fetchData();
  };

  // ═══════════════════════════════════════
  // COMPUTED METRICS
  // ═══════════════════════════════════════

  const clientesAtivos = clientes.filter((c) => c.ativo !== false);
  const clientesPausados = clientes.filter((c) => c.ativo === false);

  const calcMRR = () => {
    return clientesAtivos.reduce((sum, c) => {
      let valor = c.valor || PLANO_BASE;
      const addons = c.addons || [];
      addons.forEach((a) => { if (ADDONS[a]) valor += ADDONS[a].preco; });
      if (c.addon_dominio) valor += 9.9;
      return sum + valor;
    }, 0);
  };

  const mrr = calcMRR();
  const custoFixo = 870;
  const custoVariavel = clientesAtivos.length * 6;
  const lucroLiquido = mrr - custoFixo - custoVariavel;
  const margem = mrr > 0 ? ((lucroLiquido / mrr) * 100).toFixed(0) : 0;

  const leadsContatados = leads.filter((l) => l.status === "contactado").length;
  const leadsInteressados = leads.filter((l) => l.status === "interessado").length;
  const leadsNovos = leads.filter((l) => l.status === "novo").length;

  // ═══════════════════════════════════════
  // SIDEBAR
  // ═══════════════════════════════════════

  const tabs = [
    { id: "dashboard", label: "Dashboard", icon: LayoutDashboard },
    { id: "clientes", label: "Clientes", icon: UserCheck },
    { id: "analista", label: "IA Analista", icon: Brain },
    { id: "financeiro", label: "Financeiro", icon: DollarSign },
    { id: "pipeline", label: "Pipeline", icon: Zap },
    { id: "config", label: "Configurações", icon: Settings },
  ];

  if (!configLoaded) {
    return (
      <div style={{ display: "flex", alignItems: "center", justifyContent: "center", height: "100vh", background: "#0B1120", color: "#94A3B8" }}>
        Carregando...
      </div>
    );
  }

  if (!connected) {
    return <ConfigPanel config={config} onSave={saveConfig} />;
  }

  return (
    <div style={{ display: "flex", height: "100vh", background: "#0B1120", color: "#E2E8F0", fontFamily: "'DM Sans', -apple-system, sans-serif" }}>
      {/* Sidebar */}
      <aside style={{ width: 240, background: "#111827", borderRight: "1px solid #1E293B", display: "flex", flexDirection: "column", flexShrink: 0 }}>
        <div style={{ padding: "20px 20px 16px", borderBottom: "1px solid #1E293B" }}>
          <div style={{ fontSize: 20, fontWeight: 700, color: "#38BDF8", letterSpacing: -0.5 }}>VitrineIA</div>
          <div style={{ fontSize: 11, color: "#64748B", marginTop: 2 }}>Painel Administrativo</div>
        </div>
        <nav style={{ flex: 1, padding: "12px 8px" }}>
          {tabs.map((t) => {
            const Icon = t.icon;
            const active = activeTab === t.id;
            return (
              <button key={t.id} onClick={() => setActiveTab(t.id)} style={{
                display: "flex", alignItems: "center", gap: 10, width: "100%", padding: "10px 12px", marginBottom: 2,
                background: active ? "rgba(56,189,248,0.1)" : "transparent", border: "none", borderRadius: 8,
                color: active ? "#38BDF8" : "#94A3B8", cursor: "pointer", fontSize: 13, fontWeight: active ? 600 : 400,
                transition: "all 0.2s",
              }}>
                <Icon size={18} />
                {t.label}
              </button>
            );
          })}
        </nav>
        <div style={{ padding: 16, borderTop: "1px solid #1E293B", fontSize: 11, color: "#475569" }}>
          {lastRefresh && `Atualizado: ${lastRefresh.toLocaleTimeString("pt-BR")}`}
          <button onClick={() => fetchData()} style={{
            display: "flex", alignItems: "center", gap: 6, marginTop: 8, padding: "6px 12px",
            background: "#1E293B", border: "none", borderRadius: 6, color: "#94A3B8", cursor: "pointer", fontSize: 11, width: "100%",
          }}>
            <RefreshCw size={12} className={loading ? "spin" : ""} />
            {loading ? "Carregando..." : "Atualizar dados"}
          </button>
        </div>
      </aside>

      {/* Main Content */}
      <main style={{ flex: 1, overflow: "auto", padding: 28 }}>
        {activeTab === "dashboard" && (
          <DashboardTab clientes={clientesAtivos} clientesPausados={clientesPausados} mrr={mrr} lucro={lucroLiquido} margem={margem} leads={leads} leadsNovos={leadsNovos} leadsContatados={leadsContatados} leadsInteressados={leadsInteressados} />
        )}
        {activeTab === "clientes" && (
          <ClientesTab clientes={clientes} onToggle={toggleCliente} onUpdateAddons={updateAddons} paginas={paginas} />
        )}
        {activeTab === "analista" && (
          <AnalistaTab clientes={clientesAtivos} paginas={paginas} config={config} />
        )}
        {activeTab === "financeiro" && (
          <FinanceiroTab clientes={clientes} clientesAtivos={clientesAtivos} mrr={mrr} custoFixo={custoFixo} custoVariavel={custoVariavel} lucro={lucroLiquido} margem={margem} />
        )}
        {activeTab === "pipeline" && (
          <PipelineTab leads={leads} />
        )}
        {activeTab === "config" && (
          <ConfigPanel config={config} onSave={saveConfig} inline />
        )}
      </main>

      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .spin { animation: spin 1s linear infinite; }
      `}</style>
    </div>
  );
}

// ═══════════════════════════════════════
// KPI CARD
// ═══════════════════════════════════════

function KpiCard({ icon: Icon, label, value, sub, color = "#38BDF8" }) {
  return (
    <div style={{
      background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20,
      display: "flex", alignItems: "flex-start", gap: 14, flex: 1, minWidth: 200,
    }}>
      <div style={{ width: 40, height: 40, borderRadius: 10, background: `${color}15`, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
        <Icon size={20} color={color} />
      </div>
      <div>
        <div style={{ fontSize: 12, color: "#64748B", marginBottom: 4 }}>{label}</div>
        <div style={{ fontSize: 22, fontWeight: 700, color: "#F1F5F9" }}>{value}</div>
        {sub && <div style={{ fontSize: 11, color: "#64748B", marginTop: 2 }}>{sub}</div>}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════
// DASHBOARD TAB
// ═══════════════════════════════════════

function DashboardTab({ clientes, clientesPausados, mrr, lucro, margem, leads, leadsNovos, leadsContatados, leadsInteressados }) {
  return (
    <div>
      <h1 style={{ fontSize: 22, fontWeight: 700, marginBottom: 24, color: "#F1F5F9" }}>Dashboard</h1>

      <div style={{ display: "flex", gap: 16, flexWrap: "wrap", marginBottom: 28 }}>
        <KpiCard icon={Users} label="Clientes Ativos" value={clientes.length} sub={`${clientesPausados.length} pausados`} color="#38BDF8" />
        <KpiCard icon={DollarSign} label="MRR" value={`R$${mrr.toFixed(0)}`} sub={`Lucro: R$${lucro.toFixed(0)}`} color="#34D399" />
        <KpiCard icon={TrendingUp} label="Margem" value={`${margem}%`} sub="Líquida" color="#A78BFA" />
        <KpiCard icon={Activity} label="Leads" value={leads.length} sub={`${leadsNovos} novos · ${leadsInteressados} interessados`} color="#FB923C" />
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 20 }}>
        {/* Clientes Recentes */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20 }}>
          <h3 style={{ fontSize: 14, fontWeight: 600, marginBottom: 16, color: "#94A3B8" }}>Clientes Recentes</h3>
          {clientes.slice(0, 5).map((c, i) => (
            <div key={i} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "10px 0", borderBottom: i < 4 ? "1px solid #1E293B" : "none" }}>
              <div>
                <div style={{ fontSize: 13, fontWeight: 500, color: "#E2E8F0" }}>{c.nome || "Sem nome"}</div>
                <div style={{ fontSize: 11, color: "#64748B" }}>{c.segmento || "—"} · {c.cidade || "—"}</div>
              </div>
              <div style={{ fontSize: 11, padding: "3px 8px", borderRadius: 6, background: c.ativo !== false ? "#34D39920" : "#EF444420", color: c.ativo !== false ? "#34D399" : "#EF4444" }}>
                {c.ativo !== false ? "Ativo" : "Pausado"}
              </div>
            </div>
          ))}
          {clientes.length === 0 && <div style={{ color: "#475569", fontSize: 13 }}>Nenhum cliente ainda</div>}
        </div>

        {/* Pipeline Resumo */}
        <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, padding: 20 }}>
          <h3 style={{ fontSize: 14, fontWeight: 600, marginBottom: 16, color: "#94A3B8" }}>Pipeline de Leads</h3>
          <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
            {[
              { label: "Novos", value: leadsNovos, color: "#64748B", total: leads.length },
              { label: "Contatados", value: leadsContatados, color: "#38BDF8", total: leads.length },
              { label: "Interessados", value: leadsInteressados, color: "#34D399", total: leads.length },
              { label: "Convertidos", value: clientes.length, color: "#A78BFA", total: leads.length },
            ].map((item, i) => (
              <div key={i}>
                <div style={{ display: "flex", justifyContent: "space-between", fontSize: 12, marginBottom: 4 }}>
                  <span style={{ color: "#94A3B8" }}>{item.label}</span>
                  <span style={{ color: "#E2E8F0", fontWeight: 600 }}>{item.value}</span>
                </div>
                <div style={{ height: 6, background: "#1E293B", borderRadius: 3, overflow: "hidden" }}>
                  <div style={{ height: "100%", width: `${item.total > 0 ? (item.value / item.total) * 100 : 0}%`, background: item.color, borderRadius: 3, transition: "width 0.5s" }} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}

// ═══════════════════════════════════════
// CLIENTES TAB
// ═══════════════════════════════════════

function ClientesTab({ clientes, onToggle, onUpdateAddons, paginas }) {
  const [search, setSearch] = useState("");
  const [filter, setFilter] = useState("todos");
  const [editingAddons, setEditingAddons] = useState(null);

  const filtered = clientes.filter((c) => {
    const matchSearch = !search || (c.nome || "").toLowerCase().includes(search.toLowerCase()) || (c.segmento || "").toLowerCase().includes(search.toLowerCase());
    const matchFilter = filter === "todos" || (filter === "ativos" && c.ativo !== false) || (filter === "pausados" && c.ativo === false);
    return matchSearch && matchFilter;
  });

  const getValorCliente = (c) => {
    let v = c.valor || PLANO_BASE;
    (c.addons || []).forEach((a) => { if (ADDONS[a]) v += ADDONS[a].preco; });
    if (c.addon_dominio) v += 9.9;
    return v;
  };

  const getPagina = (clienteId) => paginas.find((p) => p.cliente_id === clienteId);

  return (
    <div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
        <h1 style={{ fontSize: 22, fontWeight: 700, color: "#F1F5F9" }}>Clientes ({clientes.length})</h1>
        <div style={{ display: "flex", gap: 10 }}>
          <div style={{ position: "relative" }}>
            <Search size={14} style={{ position: "absolute", left: 10, top: "50%", transform: "translateY(-50%)", color: "#64748B" }} />
            <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Buscar..." style={{
              padding: "8px 12px 8px 32px", background: "#1E293B", border: "1px solid #334155", borderRadius: 8, color: "#E2E8F0", fontSize: 13, width: 200, outline: "none",
            }} />
          </div>
          {["todos", "ativos", "pausados"].map((f) => (
            <button key={f} onClick={() => setFilter(f)} style={{
              padding: "8px 14px", background: filter === f ? "#38BDF820" : "#1E293B", border: `1px solid ${filter === f ? "#38BDF8" : "#334155"}`,
              borderRadius: 8, color: filter === f ? "#38BDF8" : "#94A3B8", fontSize: 12, cursor: "pointer", textTransform: "capitalize",
            }}>
              {f}
            </button>
          ))}
        </div>
      </div>

      <div style={{ background: "#111827", border: "1px solid #1E293B", borderRadius: 12, overflow: "hidden" }}>
        <table style={{ width: "100%", borderCollapse: "collapse" }}>
          <thead>
            <tr style={{ background: "#0F172A" }}>
              {["Nome", "Categoria", "Cidade", "Add-ons", "Valor/mês", "Status", "Página", "Ações"].map((h) => (
                <th key={h} style={{ padding: "12px 16px", textAlign: "left", fontSize: 11, fontWeight: 600, color: "#64748B", textTransform: "uppercase", letterSpacing: 0.5 }}>
                  {h}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {filtered.map((c) => {
              const pagina = getPagina(c.id);
              const addons = c.addons || [];
              return (
                <tr key={c.id} style={{ borderBottom: "1px solid #1E293B" }}>
                  <td style={{ padding: "12px 16px" }}>
                    <div style={{ fontSize: 13, fontWeight: 500, color: "#E2E8F0" }}>{c.nome || "—"}</div>
                    <div style={{ fontSize: 11, color: "#64748B" }}>{c.telefone || ""}</div>
                  </td>
                  <td style={{ padding: "12px 16px", fontSize: 12, color: "#94A3B8" }}>{c.segmento || "—"}</td>
                  <td style={{ padding: "12px 16px", fontSize: 12, color: "#94A3B8" }}>{c.cidade || "—"}</td>
                  <td style={{ padding: "12px 16px" }}>
                    <div style={{ display: "flex", gap: 4, flexWrap: "wrap" }}>
                      {addons.length > 0 ? addons.map((a) => (
                        <span key={a} style={{ fontSize: 10, padding: "2px 6px", background: "#38BDF815", color: "#38BDF8", borderRadius: 4 }}>
                          {ADDONS[a]?.nome?.split(" ")[0] || a}
                        </span>
                      )) : <span style={{ fontSize: 11, color: "#475569" }}>Nenhum</span>}
                    </div>
                  </td>
                  <td style={{ padding: "12px 16px", fontSize: 13, fontWeight: 600, color: "#34D399" }}>R${getValorCliente(c).toFixed(0)}</td>
                  <td style={{ padding: "12px 16px" }}>
                    <span style={{
                      fontSize: 11, padding: "3px 8px", borderRadius: 6,
                      background: c.ativo !== false ? "#34D39920" : "#EF444420",
                      color: c.ativo !== false ? "#34D399" : "#EF4444",
                    }}>
                      {c.ativo !== false ? "Ativo" : "Pausado"}
                    </span>
                  </td>
                  <td style={{ padding: "12px 16px" }}>
                    {pagina?.url_publica ? (
                      <a href={pagina.url_publica} target="_blank" rel="noreferrer" style={{ color: "#38BDF8", fontSize: 12, display: "flex", alignItems: "center", gap: 4 }}>
                        <ExternalLink size={12} /> Ver
                      </a>
                    ) : <span style={{ fontSize: 11, color: "#475569" }}>—</span>}
                  </td>
                  <td style={{ padding: "12px 16px" }}>
                    <div style={{ display: "flex", gap: 6 }}>
                      <button onClick={() => onToggle(c.id, c.ativo !== false)} title={c.ativo !== false ? "Pausar" : "Ativar"} style={{
                        padding: "5px 8px", background: "#1E293B", border: "1px solid #334155", borderRadius: 6, cursor: "pointer", color: "#94A3B8", display: "flex", alignItems: "center",
                      }}>
                        {c.ativo !== false ? <Pause size={13} /> : <Play size={13} />}
                      </button>
                      <button onClick={() => setEditingAddons(editingAddons === c.id ? null : c.id)} title="Add-ons" style={{
                        padding: "5px 8px", background: "#1E293B", border: "1px solid #334155", borderRadius: 6, cursor: "pointer", color: "#94A3B8", display: "flex", alignItems: "center",
                      }}>
                        <Plus size={13} />
                      </button>
                    </div>
                    {editingAddons === c.id && (
                      <AddonEditor current={addons} onSave={(newAddons) => { onUpdateAddons(c.id, newAddons); setEditingAddons(null); }} onClose={() => setEditingAddons(null)} />
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        {filtered.length === 0 && (
          <div style={{ padding: 40, textAlign: "center", color: "#475569", fontSize: 13 }}>Nenhum cliente encontrado</div>
        )}
      </div>
    </div>
  );
}

// ═══════════════════════════════════════
// ADDON EDITOR POPUP
// ═══════════════════════════════════════

function AddonEditor({ current, onSave, onClose }) {
  const [selected, setSelected] = useState([...current]);

  const toggle = (key) => {
    setSelected((prev) => prev.includes(key) ? prev.filter((k) => k !== key) : [...prev, key]);
  };

  return (
    <div style={{
      position: "absolute", right: 0, top: 40, zIndex: 50, background: "#1E293B", border: "1px solid #334155",
      borderRadius: 10, padding: 16, width: 260, boxShadow: "0 8px 30px rgba(0,0,0,0.4)",
    }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 12 }}>
        <span style={{ fontSize: 13, fontWeight: 600, color: "#E2E8F0" }}>Add-ons</span>
        <button onClick={onClose} style={{ background: "none", border: "none", color: "#64748B", cursor: "pointer" }}><X size={14} /></button>
      </div>
      {Object.entries(ADDONS).map(([key, addon]) => {
        const Icon = addon.icone;
        const active = selected.includes(key);
        return (
          <button key={key} onClick={() => toggle(key)} style={{
            display: "flex", alignItems: "center", gap: 8, width: "100%", padding: "8px 10px", marginBottom: 4,
            background: active ? "#38BDF815" : "transparent", border: `1px solid ${active ? "#38BDF8" : "transparent"}`,
            borderRadius: 6, cursor: "pointer", color: active ? "#38BDF8" : "#94A3B8", fontSize: 12, textAlign: "left",
          }}>
            <Icon size={14} />
            <span style={{ flex: 1 }}>{addon.nome}</span>
            <span style={{ fontSize: 11 }}>R${addon.preco}</span>
          </button>
        );
      })}
      <button onClick={() => onSave(selected)} style={{
        width: "100%", padding: "8px", marginTop: 8, background: "#38BDF8", color: "#0B1120",
        border: "none", borderRadius: 6, fontSize: 12, fontWeight: 600, cursor: "pointer",
      }}>
        Salvar
      </button>
    </div>
  );
}

