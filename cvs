          </div>
        ))}

        <button onClick={handleSave} style={{
          width: "100%", padding: "12px", background: "#38BDF8", color: "#0B1120",
          border: "none", borderRadius: 8, fontSize: 14, fontWeight: 700, cursor: "pointer", marginTop: 8,
        }}>
          {inline ? "Salvar Configurações" : "Conectar"}
        </button>

        {inline && (
          <div style={{ marginTop: 16, padding: 12, background: "#34D39915", borderRadius: 8, fontSize: 12, color: "#34D399" }}>
            ✅ Conectado ao Supabase
          </div>
        )}
      </div>
      {!inline && (
        <style>{`@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');`}</style>
      )}
    </Wrapper>
  );
}

